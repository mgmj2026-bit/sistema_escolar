<IfModule mod_rewrite.c>
    RewriteEngine On

    # Si existe archivo o carpeta real, servirlo directamente
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Todo lo demás al front controller
    RewriteRule ^ index.php [QSA,L]
</IfModule>
